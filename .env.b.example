# SCOPTIX second instance ("B") — isolated fast-lane stack for small scopes.
# Copy to .env.b (gitignored), then start with: bash docker-start-b.sh
# docker-start-b.sh auto-generates APP_ENCRYPTION_KEY if left as the placeholder.

STACK_PREFIX=scoptix2
APP_PORT=3001
POSTGRES_PORT=5433
REDIS_PORT=6380

# Host ports above; service names (postgres/redis) stay internal to the stack.
DATABASE_URL="postgresql://recon:recon@localhost:5433/recon?schema=public"
REDIS_URL="redis://127.0.0.1:6380"

# 32 bytes base64 — generate: openssl rand -base64 32
APP_ENCRYPTION_KEY="REPLACE_ME_BASE64_32_BYTES"
